<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jindam.app.review.mapper.ReviewMapper">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- 공통 SELECT 조각                                        -->
    <!-- Flutter ReviewModelKey 에 맞추어 alias 부여              -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <sql id="getSelectReview">
        /* ReviewMapper.getSelectReview */
        SELECT
             tr.review_id                AS id
            ,tr.appointment_id           AS appointment_id
            ,tr.create_id                AS customer_id
            ,ta.designer_uid             AS designer_id
            ,tr.review_type_code_arr     AS review_type
            ,tr.review_content           AS review_content
            ,tr.create_at                AS create_at
            ,tr.update_at                AS update_at
        FROM tb_review tr
        LEFT JOIN tb_appointment ta ON ta.appointment_id = tr.appointment_id
    </sql>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- resultMap: _varchar 배열 → List<String> 변환           -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <resultMap id="reviewResultMap" type="ReviewDetailResponseDto">
        <id property="id" column="id"/>
        <result property="appointmentId" column="appointment_id"/>
        <result property="customerId" column="customer_id"/>
        <result property="designerId" column="designer_id"/>
        <result property="reviewType" column="review_type"
                javaType="java.util.List" jdbcType="ARRAY"
                typeHandler="com.jindam.config.database.mybatis.ListStringArrayTypeHandler"/>
        <result property="reviewContent" column="review_content"/>
        <result property="createAt" column="create_at"/>
        <result property="updateAt" column="update_at"/>
    </resultMap>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- 후기 단건 조회                                          -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <select id="selectReviewById" parameterType="ReviewDetailRequestDto" resultMap="reviewResultMap">
        <include refid="getSelectReview" />
        <where>
            AND tr.delete_yn = 'N'
            <if test="reviewId != null">
                AND tr.review_id = #{reviewId}
            </if>
            <if test="reviewId == null and appointmentId != null">
                AND tr.appointment_id = #{appointmentId}
            </if>
        </where>
        ORDER BY tr.create_at DESC
        LIMIT 1
    </select>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- 후기 목록 조회 (페이징) 조건 조각                         -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <sql id="selectReviewsFrag">
        <where>
            AND tr.delete_yn = 'N'
            <if test="designerId != null and designerId != ''">
                AND ta.designer_uid = #{designerId}
            </if>
            <if test="customerId != null and customerId != ''">
                AND tr.create_id = #{customerId}
            </if>
            <if test="appointmentId != null and appointmentId != ''">
                AND tr.appointment_id = #{appointmentId}
            </if>
        </where>
    </sql>

    <select id="selectReviewsPaging" parameterType="ReviewDetailRequestDto" resultMap="reviewResultMap">
        <include refid="getSelectReview" />
        <include refid="selectReviewsFrag" />
        ORDER BY tr.create_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="selectReviewsPagingCount" parameterType="ReviewDetailRequestDto" resultType="int">
        SELECT COUNT(*)
        FROM tb_review tr
        LEFT JOIN tb_appointment ta ON ta.appointment_id = tr.appointment_id
        <include refid="selectReviewsFrag" />
    </select>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- 후기 생성                                               -->
    <!-- reviewType: List<String> front 값 → enum name으로       -->
    <!-- Service에서 변환 후 DB에는 배열로 저장                     -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <insert id="insertReview" parameterType="ReviewInsertRequestDto">
        /* ReviewMapper.insertReview : 후기 생성 */
        INSERT INTO tb_review (
             review_id
            ,appointment_id
            ,review_type_code_arr
            ,review_content
            ,create_at
            ,create_id
        ) VALUES (
             nextval('seq_tb_review_review_id')::text
            ,#{appointmentId}
            <if test="reviewType != null and reviewType.size() > 0">
            ,ARRAY[<foreach collection="reviewType" item="rt" separator=",">#{rt}</foreach>]::varchar[]
            </if>
            <if test="reviewType == null or reviewType.size() == 0">
            ,NULL
            </if>
            ,#{reviewContent}
            ,NOW()
            ,#{customerId}
        )
    </insert>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- 디자이너 후기 카운트 upsert                              -->
    <!-- 해당 유형이 있으면 +1, 없으면 INSERT                     -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <insert id="upsertDesignerReviewCount" parameterType="DesignerReviewUpsertDto">
        /* ReviewMapper.upsertDesignerReviewCount : 디자이너 후기 카운트 upsert */
        INSERT INTO tb_designer_review (
             designer_review_id
            ,uid
            ,review_type_code
            ,review_count
            ,create_at
            ,create_id
        ) VALUES (
             nextval('seq_tb_designer_review_designer_review_id')::text
            ,#{uid}
            ,#{reviewTypeCode}
            ,1
            ,NOW()
            ,'system'
        )
        ON CONFLICT (uid, review_type_code)
        WHERE delete_yn = 'N'
        DO UPDATE SET
            review_count = tb_designer_review.review_count + 1,
            update_at = NOW(),
            update_id = 'system'
    </insert>

</mapper>
